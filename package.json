{
  "name": "flipboard-translator",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "rspack build",
    "build:watch": "rspack build --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && tsgo --noEmit -p tsconfig.json && npm run build",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "@rspack/cli": "^1.6.2",
    "@rspack/core": "^1.6.2",
    "@types/chrome": "^0.1.14",
    "@types/firefox-webext-browser": "^120.0.4",
    "@typescript/native-preview": "^7.0.0-dev.20260307.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
