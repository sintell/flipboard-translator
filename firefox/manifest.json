{
  "manifest_version": 2,
  "name": "Flipboard Word Translator",
  "description": "Randomly replaces page words with translated words and optional transcription.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "https://api.mymemory.translated.net/*",
    "https://translate.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["src/background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Flipboard Translator",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
